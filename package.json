    "@storybook/html-vite": "^10.2.17",
    "@storybook/testing-library": "^0.2.2",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/d3": "^7.4.3",
    "@types/rbush": "^4.0.0",
    "@types/topojson-client": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chokidar": "^5.0.0",
    "chromatic": "^15.2.0",
    "concurrently": "^9.2.1",
